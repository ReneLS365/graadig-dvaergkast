{
  "name": "graadig-dvaergkast-core-refactor",
  "version": "0.14.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:game": "node tools/build-game-bundle.mjs",
    "build:single": "node tools/build-single-html.mjs",
    "check": "node tools/check-repo.mjs && npm run save:check && npm run status:check && npm run refs:check && npm run economy:check",
    "status": "node tools/status.mjs --write",
    "status:check": "node tools/status.mjs --check",
    "refs:check": "node tools/check-doc-refs.mjs",
    "smoke": "node tools/smoke-check.mjs",
    "smoke:browser": "node tools/browser-smoke.mjs",
    "balance:check": "node tools/balance-check.mjs",
    "economy:check": "npm run build:game && node tools/economy-snapshot.mjs --check",
    "economy:snapshot": "npm run build:game && node tools/economy-snapshot.mjs --write",
    "simulate": "node tools/simulate-run.mjs",
    "build": "npm run check && npm run balance:check && npm run build:game && npm run build:single",
    "dev": "npm run build:game && vite --host 0.0.0.0",
    "serve": "npm run build:game && python3 -m http.server 8080",
    "clean": "node tools/clean.mjs",
    "save:check": "node tools/save-migration-check.mjs"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  },
  "description": "GRÅDIG Dværgkast v14 core-refactor, GitHub/Codex ready."
}
